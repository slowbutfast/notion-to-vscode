# Notion Integration Token (starts with secret_)
NOTION_TOKEN=secret_your_integration_token_here

# Notion Database ID (32-character string from the database URL)
NOTION_DATABASE_ID=your_database_id_here

# VS Code Edition: 'stable' or 'insiders' (default: stable)
VSCODE_EDITION=stable

# Force projects to open in a new window: 'true' or 'false' (default: true)
VSCODE_FORCE_NEW_WINDOW=true
